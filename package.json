{
  "name": "agenda-infinity",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "mobile": "pnpm --filter @agenda/app run mobile",
    "android": "pnpm --filter @agenda/app run android",
    "ios": "pnpm --filter @agenda/app run ios",
    "lint": "turbo run lint && prettier --check .",
    "lint:fix": "turbo run lint:fix && prettier --write .",
    "lint:eslint": "eslint .",
    "lint:eslint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:generate": "node scripts/docker-api-run.cjs pnpm --filter @agenda/api exec prisma generate",
    "db:migrate": "node scripts/docker-api-run.cjs -it pnpm --filter @agenda/api exec prisma migrate dev",
    "db:push": "node scripts/docker-api-run.cjs node apps/api/scripts/db-push.cjs",
    "db:push:remap": "node scripts/docker-api-run.cjs pnpm --filter @agenda/api exec -- prisma db execute --file prisma/sql/remap_legacy_booking_status.sql",
    "db:seed": "node scripts/docker-api-run.cjs pnpm --filter @agenda/api run seed",
    "api:docker": "docker compose up --build api",
    "docker:up": "docker compose up --build",
    "docker:up:detached": "docker compose up --build -d",
    "docker:up:app": "docker compose up -d --build --force-recreate api web && docker compose ps -a",
    "perf:stress": "node perf/autocannon-stress.mjs",
    "perf:k6": "k6 run perf/k6/specialists.js"
  },
  "devDependencies": {
    "autocannon": "^8.0.0",
    "@playwright/test": "^1.49.1",
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.58.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
