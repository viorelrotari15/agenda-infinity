    "@capacitor/ios": "^7.0.0",
    "@ionic/react": "^8.4.3",
    "@ionic/react-router": "^8.4.3",
    "@tanstack/react-query": "^5.62.11",
    "i18next": "^26.0.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "ionicons": "^7.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.72.0",
    "react-i18next": "^17.0.2",
    "react-router": "^5.3.4",
    "react-router-dom": "^5.3.4"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
