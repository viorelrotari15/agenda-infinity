generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SPECIALIST
  CLIENT
}

enum BookingStatus {
  CREATED
  ACCEPTED
  DENIED
  CANCELLED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  phone     String?
  fcmToken  String?
  password  String
  role      Role
  createdAt DateTime @default(now())
  specialist SpecialistProfile?
  bookings  Booking[] @relation("ClientBookings")
  clientProfile ClientProfile?
  interests     ClientInterest[]
  reviewsAuthored Review[]
}

model SpecialistProfile {
  id          String   @id @default(cuid())
  userId       String   @unique
  displayName  String
  slug         String   @unique
  timezone     String   @default("UTC")
  /// Public listing / SEO body copy (shown on /p/:slug and in meta description)
  publicBio    String?
  /// Optional override for HTML page title; default is displayName + site name
  seoTitle     String?
  /// YYYY-MM-DD in specialist timezone; last day we sent the morning digest
  morningDigestSentForLocalDate String?
  /// Denormalized from approved reviews (updated when reviews change)
  averageRating Float    @default(0)
  reviewCount   Int      @default(0)
  /// Public profile photo (HTTPS URL); shown in directory and public pages
  publicPhotoUrl String?
  galleryImages  SpecialistGalleryImage[]
  user         User     @relation(fields: [userId], references: [id])
  services     Service[]
  workingHours WorkingHoursRule[]
  availabilityBlocks AvailabilityBlock[]
  bookings     Booking[]
  categories   SpecialistCategory[]
  reviews      Review[]
}

/// Portfolio images for specialist profile (stored in object storage; URLs are public-read).
model SpecialistGalleryImage {
  id             String   @id @default(cuid())
  specialistId   String
  objectKey      String
  publicUrl      String
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  specialist     SpecialistProfile @relation(fields: [specialistId], references: [id], onDelete: Cascade)

  @@index([specialistId, sortOrder])
}

model Category {
  id        String   @id @default(cuid())
  slug      String   @unique
  nameEn    String
  nameRo    String
  nameRu    String
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  specialists SpecialistCategory[]
  interests   ClientInterest[]
}

model SpecialistCategory {
  specialistId String
  categoryId   String
  isPrimary    Boolean @default(false)
  specialist   SpecialistProfile @relation(fields: [specialistId], references: [id], onDelete: Cascade)
  category     Category          @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([specialistId, categoryId])
  @@index([categoryId])
}

model ClientProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ClientInterest {
  userId     String
  categoryId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([userId, categoryId])
  @@index([categoryId])
}

model Review {
  id             String       @id @default(cuid())
  specialistId   String
  authorUserId   String
  rating         Int
  comment        String       @db.VarChar(2000)
  status         ReviewStatus @default(PENDING)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  specialist     SpecialistProfile @relation(fields: [specialistId], references: [id], onDelete: Cascade)
  author         User              @relation(fields: [authorUserId], references: [id], onDelete: Cascade)

  @@unique([specialistId, authorUserId])
  @@index([specialistId, status])
  @@index([status])
}

model AvailabilityBlock {
  id             String   @id @default(cuid())
  specialistId   String
  startUtc       DateTime
  endUtc         DateTime
  note           String?
  specialist     SpecialistProfile @relation(fields: [specialistId], references: [id], onDelete: Cascade)

  @@index([specialistId, startUtc, endUtc])
}

model ServiceType {
  id                     String   @id @default(cuid())
  name                   String
  defaultDurationMinutes Int
  defaultBufferMinutes   Int      @default(0)
  active                 Boolean  @default(true)
  sortOrder              Int      @default(0)
  services               Service[]
}

model Banner {
  id        String   @id @default(cuid())
  imageUrl  String
  title     String
  subtitle  String?
  linkUrl   String?
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
}

model Service {
  id              String   @id @default(cuid())
  specialistId    String
  serviceTypeId   String?
  name            String
  durationMinutes Int
  bufferMinutes   Int      @default(0)
  active          Boolean  @default(true)
  specialist      SpecialistProfile @relation(fields: [specialistId], references: [id])
  serviceType     ServiceType? @relation(fields: [serviceTypeId], references: [id])
  bookings        Booking[]
}

model WorkingHoursRule {
  id           String @id @default(cuid())
  specialistId String
  dayOfWeek    Int
  startLocal   String
  endLocal     String
  specialist   SpecialistProfile @relation(fields: [specialistId], references: [id])
}

model Booking {
  id                 String   @id @default(cuid())
  specialistId       String
  serviceId          String
  clientUserId       String?
  clientName         String
  clientEmail        String
  clientPhone        String?
  startUtc           DateTime
  endUtc             DateTime
  status             BookingStatus @default(CREATED)
  recurrenceSeriesId String?
  recurrenceRrule    String?
  createdAt          DateTime @default(now())
  /// Set when morning push/SMS/email reminder was sent for this booking
  morningReminderSentAt DateTime?
  /// Set when the ~2h-before push/SMS/email reminder was sent
  twoHourReminderSentAt DateTime?

  specialist SpecialistProfile @relation(fields: [specialistId], references: [id])
  service    Service           @relation(fields: [serviceId], references: [id])
  client     User?             @relation("ClientBookings", fields: [clientUserId], references: [id])

  @@index([specialistId, startUtc, endUtc])
}
